<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.SimulateFragment"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Rule to Simulate"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerSimulateRule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editTrials"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Number of Trials (N)"
            android:inputType="number"
            android:text="1000" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchCategoricalMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Categorical: Group by Total Outcome"
            android:checked="false"
            tools:ignore="UseSwitchCompat" />

        <androidx.gridlayout.widget.GridLayout
            android:id="@+id/modifierGridSim"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            app:columnCount="2">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="wrap_content"
                android:minWidth="200dp"
                android:layout_height="wrap_content"
                android:hint="Reroll (e.g. 1-2, Fire)"
                android:padding="4dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editRerollSim"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <EditText
                android:id="@+id/editFlatSim"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:hint="Flat Mod"
                android:inputType="numberSigned"
                android:padding="8dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <CheckBox
                    android:id="@+id/checkKeepHighestSim"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Keep High" />
                <EditText
                    android:id="@+id/editKeepHighestSim"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:hint="Qty"
                    android:inputType="number"
                    android:enabled="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <CheckBox
                    android:id="@+id/checkKeepLowestSim"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Keep Low" />
                <EditText
                    android:id="@+id/editKeepLowestSim"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:hint="Qty"
                    android:inputType="number"
                    android:enabled="false" />
            </LinearLayout>
        </androidx.gridlayout.widget.GridLayout>

        <Button
            android:id="@+id/btnRunSimulation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Run Simulation" />

        <ProgressBar
            android:id="@+id/progressSimulation"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textSimResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:lineSpacingExtra="4dp"
            android:text="Results will appear here..."
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Histogram"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_gravity="center_horizontal"
            android:text="Frequency Distribution"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <!-- Y-Axis Label (Vertical) -->
            <TextView
                android:layout_width="72dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:rotation="-90"
                android:text="Likelihood (%)"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="#F0F0F0">

                    <LinearLayout
                        android:id="@+id/layoutHistogram"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="bottom"
                        android:orientation="horizontal"
                        android:padding="8dp" />
                </HorizontalScrollView>

                <!-- X-Axis Label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Roll Result Value"
                    android:textSize="12sp"
                    android:paddingTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</ScrollView>